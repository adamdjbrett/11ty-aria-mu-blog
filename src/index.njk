---
layout: layouts/base.njk
title: Home
pagination:
  data: collections.posts
  size: 10
  reverse: true
permalink: "{% if pagination.pageNumber == 0 %}/{% else %}/page/{{ pagination.pageNumber + 1 }}/{% endif %}"
---
{% if pagination.items.length == 0 %}
  <p>No posts yet. Create some Markdown files in <code>src/posts</code>.</p>
{% else %}
  <ul class="post-list">
  {% for post in pagination.items %}
    <li>
      <h2 class="no-margin"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
      <p class="post-meta">
        <time datetime="{{ post.date | date('yyyy-LL-dd') }}">{{ post.date | date("MMMM d, yyyy") }}</time>
      </p>
      {% if post.templateContent %}
        <p>{{ post.templateContent | striptags | truncate(180) }}</p>
      {% endif %}
    </li>
  {% endfor %}
  </ul>

  <nav aria-label="Pagination">
    {% if pagination.href.previous %}<a href="{{ pagination.href.previous }}">← Newer</a>{% endif %}
    {% if pagination.href.next %}<a class="float-right" href="{{ pagination.href.next }}">Older →</a>{% endif %}
  </nav>
{% endif %}
