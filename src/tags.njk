---
pagination:
  data: collections
  size: 1
  alias: tag
  filter:
    - all
    - posts
permalink: /tags/{{ tag | slugify }}/
layout: layouts/base.njk
---
<h1>Posts tagged "{{ tag }}"</h1>
<ul class="post-list">
{% set taglist = collections[tag] %}
{% for post in taglist | reverse %}
  <li>
    <h2 class="no-margin"><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
    <p class="post-meta">
      <time datetime="{{ post.date | date('yyyy-LL-dd') }}">{{ post.date | date("MMMM d, yyyy") }}</time>
    </p>
  </li>
{% endfor %}
</ul>
<p><a href="/posts/">← All posts</a></p>
